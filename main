    <!-- MAIN SCRIPT -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let currentUser = null;
        let token = localStorage.getItem('stat_token');
        let appData = { classrooms: [], stats: [], dashboard: null };
        let charts = { todayBar: null, weekBar: null };
        let isEditingClass = false; 

        Chart.register(ChartDataLabels);
        const levels = ["อนุบาล 1", "อนุบาล 2", "อนุบาล 3", "ป.1", "ป.2", "ป.3", "ป.4", "ป.5", "ป.6"];
        
        function gsRun(funcName, ...args) {
            return new Promise((resolve, reject) => {
                google.script.run.withSuccessHandler(res => { if (res === null) reject(new Error("Null data")); else resolve(res); }).withFailureHandler(reject)[funcName](...args);
            });
        }

        const showLoader = (text = 'กำลังโหลดข้อมูล...') => { document.getElementById('loaderText').innerText = text; document.getElementById('loader').style.display = 'flex'; }
        const hideLoader = () => document.getElementById('loader').style.display = 'none';

        function toThaiDateFullWithDay(dateString) {
            if(!dateString) return 'ประจำวัน ที่ ...... เดือน .......................... พ.ศ. ............';
            const date = new Date(dateString);
            const monthsFull = ['มกราคม', 'กุมภาพันธ์', 'มีนาคม', 'เมษายน', 'พฤษภาคม', 'มิถุนายน', 'กรกฎาคม', 'สิงหาคม', 'กันยายน', 'ตุลาคม', 'พฤศจิกายน', 'ธันวาคม'];
            const daysFull = ['อาทิตย์', 'จันทร์', 'อังคาร', 'พุธ', 'พฤหัสบดี', 'ศุกร์', 'เสาร์'];
            return `ประจำวัน${daysFull[date.getDay()]} ที่ ${date.getDate()} เดือน ${monthsFull[date.getMonth()]} พ.ศ. ${date.getFullYear() + 543}`;
        }

        const todayDateStr = new Date().toISOString().split('T')[0];
        document.getElementById('dashboardDateSelect').value = todayDateStr;
        document.getElementById('statDate').value = todayDateStr;
        document.getElementById('pendingDateSelect').value = todayDateStr;
        document.getElementById('searchDate').value = todayDateStr;

        window.onload = async () => {
            levels.forEach(l => { document.getElementById('rec_level').add(new Option(l, l)); document.getElementById('u_level').add(new Option(l, l)); });
            if (token) { const uInfo = localStorage.getItem('stat_user'); if(uInfo) { currentUser = JSON.parse(uInfo); showApp(); } else handleLogout(false); } 
            else showLogin();
        };

        function showLogin() { document.getElementById('loginSection').style.display = 'flex'; document.getElementById('appSection').style.display = 'none'; }

        function showApp() {
            document.getElementById('loginSection').style.display = 'none'; document.getElementById('appSection').style.display = 'block';
            document.getElementById('currentUserInfo').innerText = `${currentUser.fullname} (${currentUser.role})`;
            
            document.querySelectorAll('.role-restricted').forEach(el => {
                const allowedRoles = el.getAttribute('data-roles').split(',');
                if (allowedRoles.includes(currentUser.role)) el.style.display = ''; else el.style.display = 'none'; 
            });

            const copyBtn = document.getElementById('copyBtnContainer');
            if(copyBtn) {
                if (currentUser.role === 'admin' || currentUser.role === 'staff') copyBtn.classList.remove('d-none'); else copyBtn.classList.add('d-none');
            }
            if(currentUser.role === 'teacher') {
                const recLevel = document.getElementById('rec_level');
                if(recLevel) { recLevel.value = currentUser.assignedLevel; recLevel.disabled = true; }
            }
            navigate('dashboard');
        }

        function toggleSidebar() { document.getElementById('sidebar').classList.toggle('show'); }

        function navigate(viewId) {
            document.querySelectorAll('.content-section').forEach(el => el.classList.remove('active'));
            const targetView = document.getElementById('view-' + viewId);
            if(targetView) targetView.classList.add('active');
            
            document.querySelectorAll('.nav-link').forEach(el => el.classList.remove('active'));
            document.querySelectorAll(`[onclick="navigate('${viewId}')"]`).forEach(el => el.classList.add('active'));

            const titles = { 'dashboard': 'แดชบอร์ด', 'record': 'บันทึกข้อมูลสถิติ', 'pending': 'ตรวจสอบการส่ง', 'reports': 'รายงานย้อนหลัง', 'classrooms': 'จัดการห้องเรียน', 'users': 'จัดการผู้ใช้', 'settings': 'ตั้งค่าระบบ' };
            document.getElementById('pageTitle').innerText = titles[viewId] || '';
            if(window.innerWidth < 768) document.getElementById('sidebar').classList.remove('show');
            loadViewData(viewId);
        }

        async function handleLogin(e) {
            e.preventDefault(); showLoader('กำลังเข้าสู่ระบบ...');
            try {
                const res = await gsRun('login', document.getElementById('username').value, document.getElementById('password').value);
                if (res.success) {
                    token = res.token; currentUser = res.user;
                    localStorage.setItem('stat_token', token); localStorage.setItem('stat_user', JSON.stringify(currentUser));
                    Swal.fire({icon: 'success', title: 'เข้าสู่ระบบสำเร็จ', timer: 1500, showConfirmButton: false}); showApp();
                } else Swal.fire({icon: 'error', title: 'เกิดข้อผิดพลาด', text: res.message});
            } catch (err) { Swal.fire({icon: 'error', title: 'Error', text: err.message}); } finally { hideLoader(); }
        }

        function handleLogout(callApi = true) {
            if(callApi && token) gsRun('logout', token, currentUser?.fullname).catch(e=>{});
            token = null; currentUser = null; localStorage.clear(); showLogin();
        }

        async function loadViewData(viewId) {
            showLoader();
            try {
                if (viewId === 'dashboard') { const res = await gsRun('getDashboard', token, document.getElementById('dashboardDateSelect').value); renderDashboard(res.data); } 
                else if (viewId === 'record') { const res = await gsRun('getClassrooms', token); appData.classrooms = res.data; renderClassroomDropdown(); }
                else if (viewId === 'pending') loadPending();
                else if (viewId === 'reports') loadReports();
                else if (viewId === 'classrooms') { const res = await gsRun('getClassrooms', token); appData.classrooms = res.data; renderClassroomsTable(res.data); }
                else if (viewId === 'users') { const res = await gsRun('getUsers', token); renderUsersTable(res.data); }
                else if (viewId === 'settings') loadSettings();
            } catch (err) { Swal.fire('Error', err.message, 'error'); if(err.message.includes('หมดอายุ')) handleLogout(false); } finally { hideLoader(); }
        }

        async function loadDashboardByDate() {
            showLoader('กำลังปรับปรุงแดชบอร์ด...');
            try { const res = await gsRun('getDashboard', token, document.getElementById('dashboardDateSelect').value); renderDashboard(res.data); } 
            catch (err) { Swal.fire('Error', err.message, 'error'); } finally { hideLoader(); }
        }

        function renderDashboard(data) {
            appData.dashboard = data;
            document.getElementById('kpi-total').innerText = data.totalStudents;
            document.getElementById('kpi-present').innerText = data.present;
            document.getElementById('kpi-absent').innerText = data.absent;
            document.getElementById('kpi-pending-rooms').innerText = data.roomsPending;

            Chart.defaults.font.family = "'Sarabun', sans-serif";
            const commonChartOptions = { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true, max: 100, ticks: { stepSize: 10 } } }, plugins: { legend: { display: false }, datalabels: { display: true, color: '#1c1c1e', anchor: 'end', align: 'top', font: { weight: 'bold', size: 11 }, formatter: function(value) { return Number(value) > 0 ? value + '%' : ''; } }, tooltip: { callbacks: { label: function(context) { return context.parsed.y + '%'; } } } } };

            if(charts.todayBar) charts.todayBar.destroy();
            charts.todayBar = new Chart(document.getElementById('todayBarChart').getContext('2d'), { type: 'bar', data: { labels: data.todayChart.labels, datasets: [{ label: 'ร้อยละการมาเรียน', data: data.todayChart.data, backgroundColor: '#34c759', borderRadius: 8, maxBarThickness: 25 }] }, options: commonChartOptions });

            if(charts.weekBar) charts.weekBar.destroy();
            charts.weekBar = new Chart(document.getElementById('weekBarChart').getContext('2d'), { type: 'bar', data: { labels: data.weekChart.labels, datasets: [{ label: 'ร้อยละการมาเรียนสัปดาห์นี้', data: data.weekChart.data, backgroundColor: '#007aff', borderRadius: 8, maxBarThickness: 25 }] }, options: commonChartOptions });
        }

        function copySummary() {
            if(!appData.dashboard) return;
            const d = appData.dashboard;
            const targetDateInput = document.getElementById('dashboardDateSelect').value;
            const dateObj = new Date(targetDateInput);
            const days = ['อาทิตย์', 'จันทร์', 'อังคาร', 'พุธ', 'พฤหัสบดี', 'ศุกร์', 'เสาร์'];
            const months = ['มกราคม', 'กุมภาพันธ์', 'มีนาคม', 'เมษายน', 'พฤษภาคม', 'มิถุนายน', 'กรกฎาคม', 'สิงหาคม', 'กันยายน', 'ตุลาคม', 'พฤศจิกายน', 'ธันวาคม'];
            const dateStr = `วัน${days[dateObj.getDay()]} ที่ ${dateObj.getDate()} เดือน ${months[dateObj.getMonth()]} พ.ศ. ${dateObj.getFullYear() + 543}`;

            let text = `📊 สถิตินักเรียน ประจำ${dateStr}\n\n`;
            text += `👥 ทั้งเรียนทั้งหมด ${d.totalStudents} คน (ชาย ${d.totalMale} คน, หญิง ${d.totalFemale} คน)\n\n`;

            let presentPer = d.totalStudents > 0 ? ((d.present / d.totalStudents) * 100).toFixed(2) : 0;
            text += `✅ มาเรียน จำนวน ${d.present} คน (ร้อยละ ${presentPer})\n`;
            
            const levelOrder = ["อนุบาล 1", "อนุบาล 2", "อนุบาล 3", "ป.1", "ป.2", "ป.3", "ป.4", "ป.5", "ป.6"];
            const levelMap = {"อนุบาล 1": "อ.1", "อนุบาล 2": "อ.2", "อนุบาล 3": "อ.3", "ป.1": "ป.1", "ป.2": "ป.2", "ป.3": "ป.3", "ป.4": "ป.4", "ป.5": "ป.5", "ป.6": "ป.6"};
            
            // เรียงลำดับมาเรียน
            levelOrder.forEach(lvl => {
                if(d.levelSummary[lvl] && d.levelSummary[lvl].total > 0) {
                    let stat = d.levelSummary[lvl];
                    let per = ((stat.present / stat.total) * 100).toFixed(2);
                    text += `   📍 ${levelMap[lvl]} = ${stat.present} คน (ร้อยละ ${per})\n`;
                }
            });

            let absentPer = d.totalStudents > 0 ? ((d.absent / d.totalStudents) * 100).toFixed(2) : 0;
            text += `\n❌ ไม่มาเรียน จำนวน ${d.absent} คน (ร้อยละ ${absentPer})\n`;
            
            // เรียงลำดับไม่มาเรียน
            levelOrder.forEach(lvl => {
                if(d.levelSummary[lvl] && d.levelSummary[lvl].total > 0) {
                    let stat = d.levelSummary[lvl];
                    let per = ((stat.absent / stat.total) * 100).toFixed(2);
                    text += `   📍 ${levelMap[lvl]} = ${stat.absent} คน (ร้อยละ ${per})\n`;
                }
            });

            text += `\n✨ ขอบคุณคุณครูทุกท่านที่ให้ความร่วมมือครับ/ค่ะ 🏫💚`;
            
            navigator.clipboard.writeText(text).then(() => {
                Swal.fire({icon:'success', title:'คัดลอกลงคลิปบอร์ดแล้ว', text:'นำไปวางใน LINE ได้เลยครับ', timer:1500, showConfirmButton:false});
            }).catch(()=> { Swal.fire('Error', 'ไม่สามารถคัดลอกได้', 'error'); });
        }

        let currentLevelRooms = [];

        function renderClassroomDropdown() {
            const select = document.getElementById('statLevelSelect');
            if(!select) return;
            select.innerHTML = '<option value="">-- เลือกระดับชั้น --</option>';
            let levels = [...new Set(appData.classrooms.map(c => c.level))];
            const levelOrder = { "อนุบาล 1": 1, "อนุบาล 2": 2, "อนุบาล 3": 3, "ป.1": 4, "ป.2": 5, "ป.3": 6, "ป.4": 7, "ป.5": 8, "ป.6": 9 };
            levels.sort((a,b) => (levelOrder[a]||99) - (levelOrder[b]||99));
            levels.forEach(l => { select.innerHTML += `<option value="${l}">${l}</option>`; });
            
            if(currentUser && currentUser.role === 'teacher' && currentUser.assignedLevel !== 'All') {
                select.value = currentUser.assignedLevel; select.disabled = true; generateRecordTable();
            } else { select.disabled = false; }
        }

        async function generateRecordTable() {
            const level = document.getElementById('statLevelSelect').value;
            const container = document.getElementById('tableContainer');
            const tbody = document.getElementById('recordTableBody');
            const date = document.getElementById('statDate').value;
            
            if (!level || !date) { container.classList.add('d-none'); return; }
            showLoader('กำลังเรียกข้อมูล...');
            try {
                const res = await gsRun('getClassroomsWithStats', token, date, level);
                currentLevelRooms = res.data;
                container.classList.remove('d-none'); tbody.innerHTML = '';
                
                currentLevelRooms.forEach((c, index) => {
                    const tm = parseInt(c.totalMale) || 0, tf = parseInt(c.totalFemale) || 0, tt = tm + tf;
                    const savedM = c.savedMaleAbsent || 0, savedF = c.savedFemaleAbsent || 0;
                    tbody.innerHTML += `
                        <tr id="row_${c.classId}">
                            <td class="border-end">${index + 1}</td><td>${c.level}</td><td class="border-end fw-bold">${c.room}</td>
                            <td class="text-secondary">${tm}</td><td class="text-secondary">${tf}</td><td class="border-end fw-bold text-secondary">${tt}</td>
                            <td id="pm_${c.classId}" class="text-success">${tm - savedM}</td><td id="pf_${c.classId}" class="text-success">${tf - savedF}</td>
                            <td id="pt_${c.classId}" class="text-success fw-bold">${tt - (savedM + savedF)}</td><td id="pp_${c.classId}" class="border-end text-success">100.00%</td>
                            <td><input type="number" class="form-control form-control-sm text-center mx-auto rounded-pill border-danger" id="am_${c.classId}" value="${savedM}" min="0" max="${tm}" oninput="recalcRow('${c.classId}', ${tm}, ${tf})" style="width:70px;"></td>
                            <td><input type="number" class="form-control form-control-sm text-center mx-auto rounded-pill border-danger" id="af_${c.classId}" value="${savedF}" min="0" max="${tf}" oninput="recalcRow('${c.classId}', ${tm}, ${tf})" style="width:70px;"></td>
                            <td id="at_${c.classId}" class="text-danger fw-bold">${savedM + savedF}</td><td id="ap_${c.classId}" class="text-danger fw-bold">0.00%</td>
                        </tr>
                    `;
                    setTimeout(() => recalcRow(c.classId, tm, tf), 10);
                });
                setTimeout(() => recalcTotal(), 100);
            } catch(err) { Swal.fire('Error', err.message, 'error'); } finally { hideLoader(); }
        }

        function recalcRow(classId, totalMale, totalFemale) {
            let amInput = document.getElementById(`am_${classId}`), afInput = document.getElementById(`af_${classId}`);
            if(!amInput || !afInput) return;
            let am = parseInt(amInput.value) || 0, af = parseInt(afInput.value) || 0;
            if (am > totalMale) { am = totalMale; amInput.value = am; } if (af > totalFemale) { af = totalFemale; afInput.value = af; }
            if (am < 0) { am = 0; amInput.value = 0; } if (af < 0) { af = 0; afInput.value = 0; }
            let pm = totalMale - am, pf = totalFemale - af;
            let total = totalMale + totalFemale, pt = pm + pf, at = am + af;
            let pp = total > 0 ? ((pt / total) * 100).toFixed(2) : 0, ap = total > 0 ? ((at / total) * 100).toFixed(2) : 0;
            document.getElementById(`pm_${classId}`).innerText = pm; document.getElementById(`pf_${classId}`).innerText = pf;
            document.getElementById(`pt_${classId}`).innerText = pt; document.getElementById(`pp_${classId}`).innerText = `${pp}%`;
            document.getElementById(`at_${classId}`).innerText = at; document.getElementById(`ap_${classId}`).innerText = `${ap}%`;
            recalcTotal();
        }

        function recalcTotal() {
            let sum_tm=0, sum_tf=0, sum_tt=0, sum_pm=0, sum_pf=0, sum_pt=0, sum_am=0, sum_af=0, sum_at=0;
            if(!currentLevelRooms || currentLevelRooms.length === 0) return;
            currentLevelRooms.forEach(c => {
                let tm = parseInt(c.totalMale) || 0, tf = parseInt(c.totalFemale) || 0;
                let amEl = document.getElementById(`am_${c.classId}`), afEl = document.getElementById(`af_${c.classId}`);
                if (!amEl || !afEl) return;
                let am = parseInt(amEl.value) || 0, af = parseInt(afEl.value) || 0;
                let pm = tm - am, pf = tf - af;
                sum_tm += tm; sum_tf += tf; sum_tt += (tm + tf); sum_pm += pm; sum_pf += pf; sum_pt += (pm + pf); sum_am += am; sum_af += af; sum_at += (am + af);
            });
            let pp = sum_tt > 0 ? ((sum_pt / sum_tt) * 100).toFixed(2) : 0, ap = sum_tt > 0 ? ((sum_at / sum_tt) * 100).toFixed(2) : 0;
            const foot = document.getElementById('recordTableFoot');
            if(foot) {
                foot.innerHTML = `<tr><td colspan="3" class="text-end pe-3 border-end">รวมระดับชั้น</td><td class="text-secondary">${sum_tm}</td><td class="text-secondary">${sum_tf}</td><td class="border-end text-secondary">${sum_tt}</td><td class="text-success">${sum_pm}</td><td class="text-success">${sum_pf}</td><td class="text-success">${sum_pt}</td><td class="border-end text-success">${pp}%</td><td class="text-danger">${sum_am}</td><td class="text-danger">${sum_af}</td><td class="text-danger">${sum_at}</td><td class="text-danger">${ap}%</td></tr>`;
            }
        }

        async function saveMultipleStatData(e) {
            e.preventDefault();
            const date = document.getElementById('statDate').value; const level = document.getElementById('statLevelSelect').value;
            if(!date || !level || currentLevelRooms.length === 0) return;
            let records = [];
            for (let c of currentLevelRooms) {
                let tm = parseInt(c.totalMale) || 0, tf = parseInt(c.totalFemale) || 0;
                let am = parseInt(document.getElementById(`am_${c.classId}`).value) || 0, af = parseInt(document.getElementById(`af_${c.classId}`).value) || 0;
                let pm = tm - am, pf = tf - af;
                records.push({ date: date, level: c.level, room: c.room, classroomName: c.classroomName, male: am, female: af, present: pm + pf, absent: am + af });
            }
            showLoader('กำลังบันทึกข้อมูล...');
            try {
                const res = await gsRun('saveMultipleStatistics', token, { date, level, records });
                if (res.success) { Swal.fire('สำเร็จ', res.message, 'success'); generateRecordTable(); }
            } catch(err) { Swal.fire('ข้อผิดพลาด', err.message, 'error'); } finally { hideLoader(); }
        }

        async function loadPending() {
            showLoader('กำลังประมวลผลสถานะ...');
            try {
                const date = document.getElementById('pendingDateSelect').value;
                const res = await gsRun('getPendingRooms', token, date);
                const alertContainer = document.getElementById('pendingStatusAlert');
                const tbody = document.getElementById('pendingTableBody');
                const pendingRooms = res.data.filter(r => r.status === 'pending');
                
                if (pendingRooms.length === 0) {
                    alertContainer.innerHTML = `<div class="alert alert-success d-flex align-items-center gap-3 rounded-4 shadow-sm border-0 py-3" style="background: rgba(52, 199, 89, 0.15);"><i class="bi bi-check-circle-fill text-success fs-3"></i><div><h5 class="alert-heading fw-bold mb-1 text-success">ส่งครบทุกห้องเรียน</h5><p class="mb-0 text-dark opacity-75">ส่งข้อมูลเสร็จสิ้นสมบูรณ์เรียบร้อยแล้วในวันนี้</p></div></div>`;
                } else {
                    alertContainer.innerHTML = `<div class="alert alert-warning d-flex align-items-center gap-3 rounded-4 shadow-sm border-0 py-3" style="background: rgba(255, 204, 0, 0.15);"><i class="bi bi-exclamation-triangle-fill text-warning fs-3"></i><div><h5 class="alert-heading fw-bold mb-1 text-warning">ยังคงมีห้องเรียนค้างส่งข้อมูล</h5><p class="mb-0 text-dark opacity-75">พบว่ายังค้างการส่งข้อมูลจำนวน <strong>${pendingRooms.length} ห้องเรียน</strong></p></div></div>`;
                }
                tbody.innerHTML = res.data.map(d => `<tr><td class="fw-bold">${d.classroomName}</td><td>${d.teacher || '-'}</td><td>${d.status === 'sent' ? '<span class="badge bg-success rounded-pill px-3 py-2"><i class="bi bi-check-circle-fill"></i> ส่งเรียบร้อยแล้ว</span>' : '<span class="badge bg-danger rounded-pill px-3 py-2"><i class="bi bi-x-circle-fill"></i> ยังค้างส่งข้อมูล</span>'}</td></tr>`).join('');
            } catch (err) { Swal.fire('Error', err.message, 'error'); } finally { hideLoader(); }
        }

        function updateSignatures(dateStr, settings) {
            const d = new Date(dateStr); let day = d.getDay(); 
            let teacherName = '', headName = '';
            if(day >= 1 && day <= 5) { teacherName = settings[`teacher_${day}`] || ''; headName = settings[`head_${day}`] || ''; }
            let directorName = settings['director_name'] || '';
            
            const emptySpace = '&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;';
            
            document.getElementById('sign_teacher_name').innerHTML = teacherName ? teacherName : emptySpace;
            document.getElementById('sign_head_name').innerHTML = headName ? headName : emptySpace;
            document.getElementById('sign_director_name').innerHTML = directorName ? directorName : emptySpace;
        }

        async function loadReports() {
            showLoader('กำลังรวบรวมตารางข้อมูลสถิติ...');
            try {
                const targetDate = document.getElementById('searchDate').value;
                document.getElementById('reportHeaderDate').innerText = toThaiDateFullWithDay(targetDate);
                
                const [res, settingsRes] = await Promise.all([gsRun('getDetailedReportData', token, targetDate), gsRun('getSettings', token)]);
                
                document.getElementById('rep_semester').innerText = settingsRes.data.semester || '1';
                document.getElementById('rep_year').innerText = settingsRes.data.academic_year || '2567';
                updateSignatures(targetDate, settingsRes.data);

                const tbody = document.getElementById('reportPrintTableBody'); const tfoot = document.getElementById('reportPrintTableFoot');
                tbody.innerHTML = ''; tfoot.innerHTML = '';
                let globalIndex = 1;
                if (res.data.reportItems.length === 0) { tbody.innerHTML = `<tr><td colspan="13" class="py-5 text-center text-muted">ไม่พบข้อมูลสถิติในวันที่เลือก</td></tr>`; return; }

                res.data.reportItems.forEach(item => {
                    item.rooms.forEach(room => {
                        tbody.innerHTML += `<tr><td>${globalIndex++}</td><td class="fw-bold">${room.classroomName}</td><td>${room.totalMale}</td><td>${room.totalFemale}</td><td class="fw-bold">${room.totalStudent}</td><td>${room.presentMale}</td><td>${room.presentFemale}</td><td class="fw-bold">${room.presentTotal}</td><td class="fw-bold text-success">${room.presentPercent}%</td><td>${room.absentMale}</td><td>${room.absentFemale}</td><td class="fw-bold">${room.absentTotal}</td><td class="fw-bold text-danger">${room.absentPercent}%</td></tr>`;
                    });
                    tbody.innerHTML += `<tr class="table-secondary fw-bold" style="background-color: #e2e3e5 !important;"><td colspan="2" class="text-center">รวมระดับชั้น ${item.level}</td><td>${item.summary.totalMale}</td><td>${item.summary.totalFemale}</td><td>${item.summary.totalStudent}</td><td>${item.summary.presentMale}</td><td>${item.summary.presentFemale}</td><td>${item.summary.presentTotal}</td><td class="text-success">${item.summary.presentPercent}%</td><td>${item.summary.absentMale}</td><td>${item.summary.absentFemale}</td><td>${item.summary.absentTotal}</td><td class="text-danger">${item.summary.absentPercent}%</td></tr>`;
                });

                const gt = res.data.grandTotal;
                tfoot.innerHTML = `<tr class="table-dark text-white fw-bold" style="background-color: #212529 !important;"><td colspan="2" class="text-center">รวมทั้งสิ้น</td><td>${gt.totalMale}</td><td>${gt.totalFemale}</td><td>${gt.totalStudent}</td><td>${gt.presentMale}</td><td>${gt.presentFemale}</td><td>${gt.presentTotal}</td><td>${gt.presentPercent}%</td><td>${gt.absentMale}</td><td>${gt.absentFemale}</td><td>${gt.absentTotal}</td><td>${gt.absentPercent}%</td></tr>`;
            } catch (err) { Swal.fire('Error', err.message, 'error'); } finally { hideLoader(); }
        }

        async function loadSettings() {
            showLoader();
            try {
                const res = await gsRun('getSettings', token);
                const s = res.data;
                document.getElementById('set_semester').value = s['semester'] || '1';
                document.getElementById('set_academic_year').value = s['academic_year'] || new Date().getFullYear() + 543;
                document.getElementById('set_director_name').value = s['director_name'] || '';
                for(let i = 1; i <= 5; i++) {
                    document.getElementById(`set_teacher_${i}`).value = s[`teacher_${i}`] || '';
                    document.getElementById(`set_head_${i}`).value = s[`head_${i}`] || '';
                }
            } catch(err) { Swal.fire('Error', err.message, 'error'); } finally { hideLoader(); }
        }

        async function saveSettings(e) {
            e.preventDefault();
            let s = { 
                'semester': document.getElementById('set_semester').value,
                'academic_year': document.getElementById('set_academic_year').value,
                'director_name': document.getElementById('set_director_name').value 
            };
            for(let i = 1; i <= 5; i++) {
                s[`teacher_${i}`] = document.getElementById(`set_teacher_${i}`).value;
                s[`head_${i}`] = document.getElementById(`set_head_${i}`).value;
            }
            showLoader('กำลังบันทึกการตั้งค่า...');
            try {
                const res = await gsRun('saveSettingsBulk', token, s);
                if(res.success) Swal.fire('สำเร็จ', res.message, 'success');
            } catch(err) { Swal.fire('Error', err.message, 'error'); } finally { hideLoader(); }
        }

        function renderClassroomsTable(data) { 
            isEditingClass = false; const tbody = document.getElementById('classTableBody');
            tbody.innerHTML = data.map(d => `<tr id="row_${d.classId}"><td>${d.level}</td><td class="fw-bold">${d.room}</td><td><span class="badge bg-light text-dark border shadow-sm rounded-pill px-3 py-2">${d.classroomName}</span></td><td>${d.teacherName || '-'}</td><td>${d.totalMale}</td><td>${d.totalFemale}</td><td class="fw-bold text-primary">${d.totalStudent}</td><td><button class="btn btn-sm btn-light text-primary shadow-sm rounded-circle mx-1" onclick="editClassRow('${d.classId}')" title="แก้ไข"><i class="bi bi-pencil-fill"></i></button><button class="btn btn-sm btn-light text-danger shadow-sm rounded-circle" onclick="deleteClass('${d.classId}')" title="ลบ"><i class="bi bi-trash-fill"></i></button></td></tr>`).join(''); 
        }

        function addClassroomRow() {
            if (isEditingClass) return Swal.fire('แจ้งเตือน', 'กรุณาบันทึกหรือยกเลิกรายการที่กำลังแก้ไขก่อน', 'warning');
            isEditingClass = true;
            const tbody = document.getElementById('classTableBody'); const tr = document.createElement('tr'); tr.id = 'row_new'; tr.className = 'glass-row';
            tr.innerHTML = `<td><select class="form-select form-select-sm shadow-none rounded-pill" id="inline_level"><option value="อนุบาล 1">อนุบาล 1</option><option value="อนุบาล 2">อนุบาล 2</option><option value="อนุบาล 3">อนุบาล 3</option><option value="ป.1">ป.1</option><option value="ป.2">ป.2</option><option value="ป.3">ป.3</option><option value="ป.4">ป.4</option><option value="ป.5">ป.5</option><option value="ป.6">ป.6</option></select></td><td><input type="number" class="form-control form-control-sm shadow-none rounded-pill text-center" id="inline_room" placeholder="ห้อง" style="width:70px; margin:auto;"></td><td><span class="badge bg-secondary rounded-pill px-3 py-2 opacity-50">Auto</span></td><td><input type="text" class="form-control form-control-sm shadow-none rounded-pill" id="inline_teacher" placeholder="ชื่อครู"></td><td><input type="number" class="form-control form-control-sm shadow-none rounded-pill text-center" id="inline_male" value="0" style="width:70px; margin:auto;"></td><td><input type="number" class="form-control form-control-sm shadow-none rounded-pill text-center" id="inline_female" value="0" style="width:70px; margin:auto;"></td><td><span class="badge bg-secondary rounded-pill px-3 py-2 opacity-50">Auto</span></td><td><button class="btn btn-sm btn-success shadow-sm rounded-pill px-3 me-1" onclick="saveInlineClass('')"><i class="bi bi-check-lg"></i></button><button class="btn btn-sm btn-danger shadow-sm rounded-pill px-3" onclick="cancelInlineClass()"><i class="bi bi-x-lg"></i></button></td>`;
            tbody.appendChild(tr); tr.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        function editClassRow(classId) {
            if (isEditingClass) return Swal.fire('แจ้งเตือน', 'กรุณาบันทึกหรือยกเลิกรายการที่กำลังแก้ไขก่อน', 'warning');
            isEditingClass = true;
            const row = document.getElementById(`row_${classId}`); const d = appData.classrooms.find(c => c.classId === classId); row.className = 'glass-row';
            row.innerHTML = `<td><select class="form-select form-select-sm shadow-none rounded-pill" id="inline_level_${classId}"><option value="อนุบาล 1" ${d.level=='อนุบาล 1'?'selected':''}>อนุบาล 1</option><option value="อนุบาล 2" ${d.level=='อนุบาล 2'?'selected':''}>อนุบาล 2</option><option value="อนุบาล 3" ${d.level=='อนุบาล 3'?'selected':''}>อนุบาล 3</option><option value="ป.1" ${d.level=='ป.1'?'selected':''}>ป.1</option><option value="ป.2" ${d.level=='ป.2'?'selected':''}>ป.2</option><option value="ป.3" ${d.level=='ป.3'?'selected':''}>ป.3</option><option value="ป.4" ${d.level=='ป.4'?'selected':''}>ป.4</option><option value="ป.5" ${d.level=='ป.5'?'selected':''}>ป.5</option><option value="ป.6" ${d.level=='ป.6'?'selected':''}>ป.6</option></select></td><td><input type="number" class="form-control form-control-sm shadow-none rounded-pill text-center" id="inline_room_${classId}" value="${d.room}" style="width:70px; margin:auto;"></td><td><span class="badge bg-light text-dark border shadow-sm rounded-pill px-3 py-2">${d.classroomName}</span></td><td><input type="text" class="form-control form-control-sm shadow-none rounded-pill" id="inline_teacher_${classId}" value="${d.teacherName}"></td><td><input type="number" class="form-control form-control-sm shadow-none rounded-pill text-center" id="inline_male_${classId}" value="${d.totalMale}" style="width:70px; margin:auto;"></td><td><input type="number" class="form-control form-control-sm shadow-none rounded-pill text-center" id="inline_female_${classId}" value="${d.totalFemale}" style="width:70px; margin:auto;"></td><td class="fw-bold text-primary">${d.totalStudent}</td><td><button class="btn btn-sm btn-success shadow-sm rounded-pill px-3 me-1" onclick="saveInlineClass('${classId}')"><i class="bi bi-check-lg"></i></button><button class="btn btn-sm btn-danger shadow-sm rounded-pill px-3" onclick="cancelInlineClass()"><i class="bi bi-x-lg"></i></button></td>`;
        }

        function cancelInlineClass() { renderClassroomsTable(appData.classrooms); }

        async function saveInlineClass(classId) {
            const idSuffix = classId ? `_${classId}` : '';
            const level = document.getElementById(`inline_level${idSuffix}`).value;
            const room = document.getElementById(`inline_room${idSuffix}`).value;
            const teacher = document.getElementById(`inline_teacher${idSuffix}`).value;
            const male = document.getElementById(`inline_male${idSuffix}`).value;
            const female = document.getElementById(`inline_female${idSuffix}`).value;
            if (!level || !room || male === '' || female === '') return Swal.fire('แจ้งเตือน', 'กรุณากรอกข้อมูลให้ครบถ้วน', 'warning');
            const p = { classId: classId, level: level, room: room, teacherName: teacher, totalMale: male, totalFemale: female };
            showLoader('กำลังบันทึก...');
            try { const res = await gsRun('saveClassroom', token, p); if(res.success) { Swal.fire({icon: 'success', title: 'บันทึกสำเร็จ', timer: 1500, showConfirmButton: false}); loadViewData('classrooms'); } } catch(err) { Swal.fire('Error', err.message, 'error'); } finally { hideLoader(); }
        }

        async function deleteClass(id) {
            Swal.fire({title: 'ยืนยันการลบ?', icon: 'warning', showCancelButton: true}).then(async conf => {
                if(conf.isConfirmed) { showLoader(); try{ await gsRun('deleteClassroom', token, id); loadViewData('classrooms'); } catch(e){ Swal.fire('Error', e.message, 'error'); } finally { hideLoader(); } }
            });
        }

        let userModalInst;
        function renderUsersTable(data) { document.getElementById('userTableBody').innerHTML = data.map(d => `<tr><td class="fw-bold">${d.fullname}</td><td>${d.username}</td><td><span class="badge bg-secondary rounded-pill">${d.role}</span></td><td>${d.role==='teacher'?d.assignedLevel:'-'}</td><td><button class="btn btn-sm btn-light text-primary shadow-sm rounded-circle mx-1" onclick="editUser('${d.userId}', '${d.fullname}', '${d.username}', '${d.role}', '${d.assignedLevel}')"><i class="bi bi-pencil-fill"></i></button> <button class="btn btn-sm btn-light text-danger shadow-sm rounded-circle" onclick="deleteUser('${d.userId}')"><i class="bi bi-trash-fill"></i></button></td></tr>`).join(''); }

        function toggleAssignedLevel() { document.getElementById('u_level_div').style.display = document.getElementById('u_role').value === 'teacher' ? 'block' : 'none'; }
        
        function openUserModal() { document.getElementById('userForm').reset(); document.getElementById('u_id').value = ''; document.getElementById('u_user').readOnly = false; document.getElementById('u_pass').required = true; toggleAssignedLevel(); if(!userModalInst) userModalInst = new bootstrap.Modal(document.getElementById('userModal')); userModalInst.show(); }
        
        function editUser(id, name, user, role, level) { document.getElementById('u_id').value = id; document.getElementById('u_name').value = name; document.getElementById('u_user').value = user; document.getElementById('u_user').readOnly = true; document.getElementById('u_pass').required = false; document.getElementById('u_role').value = role; document.getElementById('u_level').value = level; toggleAssignedLevel(); if(!userModalInst) userModalInst = new bootstrap.Modal(document.getElementById('userModal')); userModalInst.show(); }
        
        async function saveUserData(e) {
            e.preventDefault();
            const p = { userId: document.getElementById('u_id').value, fullname: document.getElementById('u_name').value, username: document.getElementById('u_user').value, password: document.getElementById('u_pass').value, role: document.getElementById('u_role').value, assignedLevel: document.getElementById('u_role').value === 'teacher' ? document.getElementById('u_level').value : 'All' };
            showLoader();
            try { const res = await gsRun('saveUser', token, p); if(res.success){ Swal.fire('สำเร็จ', res.message, 'success'); userModalInst.hide(); loadViewData('users'); } } catch(err) { Swal.fire('Error', err.message, 'error'); } finally { hideLoader(); }
        }

        async function deleteUser(id) {
            Swal.fire({title: 'ยืนยันการลบผู้ใช้?', text:'ข้อมูลจะถูกลบถาวร', icon: 'warning', showCancelButton: true}).then(async conf => {
                if(conf.isConfirmed) { showLoader(); try{ await gsRun('deleteUser', token, id); loadViewData('users'); } catch(e){ Swal.fire('Error', e.message, 'error'); } finally { hideLoader(); } }
            });
        }
    </script>
